# ─── InsForge (Backend-as-a-Service) ────────────────────
# Get these from your InsForge dashboard under Project Settings > API Keys
INSFORGE_URL=https://your-app.region.insforge.app
INSFORGE_ANON_KEY=your-anon-key-here
INSFORGE_SERVICE_KEY=your-service-key-here

# ─── Vite (baked into client bundle at build time) ──────
# These are REQUIRED for Docker builds - they get baked into the client JS bundle
# Railway: Set these as "VITE_INSFORGE_BASE_URL", "VITE_INSFORGE_ANON_KEY", and "VITE_FRONTEND_URL" in your service variables
VITE_API_URL=/api
VITE_INSFORGE_BASE_URL=https://your-app.region.insforge.app
VITE_INSFORGE_ANON_KEY=your-anon-key-here
VITE_FRONTEND_URL=https://your-app.up.railway.app

# ─── App ────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
# Set to your production URL for CORS (e.g., https://your-app.up.railway.app)
# MUST be set via environment variable in production
FRONTEND_URL=
PORT=3001

# ─── Direct PostgreSQL (for CSV import) ──────────────────
DB_HOST=your-db-host.region.database.insforge.app
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=insforge
DB_USER_ID=your-user-uuid

# ─── Twilio Credentials (reference only) ─────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_CALLER_ID=