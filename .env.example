# ─── InsForge (Backend-as-a-Service) ────────────────────
INSFORGE_URL=https://your-app.region.insforge.app
INSFORGE_ANON_KEY=
INSFORGE_SERVICE_KEY=

# ─── Vite (baked into client bundle at build time) ──────
VITE_API_URL=/api
VITE_INSFORGE_BASE_URL=https://your-app.region.insforge.app
VITE_INSFORGE_ANON_KEY=

# ─── App ────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
FRONTEND_URL=http://localhost:5173
PORT=3001

# ─── Direct PostgreSQL (for CSV import) ──────────────────
DB_HOST=your-db-host.region.database.insforge.app
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=insforge
DB_USER_ID=your-user-uuid

# ─── Twilio Credentials (reference only) ─────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_CALLER_ID=